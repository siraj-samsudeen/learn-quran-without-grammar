#!/bin/bash
# Pre-commit hook: validates lesson files before committing.
# Activated by: tools/install-hooks.sh (sets core.hooksPath = tools/hooks)

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Find which lessons were modified in this commit (only .md files — skip pickers, images, etc.)
MODIFIED_LESSONS=$(git diff --cached --name-only | grep '^lessons/.*\.md$' | sed 's|lessons/lesson-\([0-9]*\).*|lesson-\1|' | sort -u)

if [ -z "$MODIFIED_LESSONS" ]; then
    exit 0  # No lesson files modified
fi

FAILED=0

for lesson in $MODIFIED_LESSONS; do
    echo "🔍 Validating $lesson..."

    if "$REPO_ROOT/tools/validate-lesson.sh" "$lesson"; then
        echo "✅ $lesson passed validation"
    else
        echo "❌ Validation failed for $lesson"
        FAILED=1
    fi
done

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "❌ Fix validation errors before committing."
    echo "   To bypass (emergency): git commit --no-verify"
    exit 1
fi

exit 0
